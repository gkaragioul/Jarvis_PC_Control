#!/usr/bin/env bash
set -euo pipefail

SSH_HOST="${JARVIS_PC_SSH_HOST:-jarvis-pc}"

PS_SCRIPT=$(cat <<'PS'
$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$enableTasks = @("Ollama GPU Server", "Ollama GPU Server Watchdog", "Jarvis Remote TTS Server", "Jarvis PC Voice Server")
foreach ($task in $enableTasks) {
  Enable-ScheduledTask -TaskName $task -ErrorAction SilentlyContinue | Out-Null
}

$ollama = Get-NetTCPConnection -LocalPort 11434 -State Listen -ErrorAction SilentlyContinue
if (-not $ollama) {
  Start-ScheduledTask -TaskName "Ollama GPU Server" -ErrorAction Stop | Out-Null
}

$ollamaReady = $false
foreach ($attempt in 1..20) {
  Start-Sleep -Seconds 1
  $ollama = Get-NetTCPConnection -LocalPort 11434 -State Listen -ErrorAction SilentlyContinue
  if ($ollama) {
    $ollamaReady = $true
    break
  }
}

if (-not $ollamaReady) {
  Write-Error "Ollama did not start on port 11434"
  exit 1
}

Start-ScheduledTask -TaskName "Ollama GPU Server Watchdog" -ErrorAction SilentlyContinue | Out-Null

$voiceTasks = @("Jarvis Remote TTS Server", "Jarvis PC Voice Server")
foreach ($task in $voiceTasks) {
  Start-ScheduledTask -TaskName $task -ErrorAction Stop | Out-Null
}

Start-Sleep -Seconds 8

$ports = @(11550, 11551)
$listening = @()
foreach ($port in $ports) {
  $connection = Get-NetTCPConnection -LocalPort $port -State Listen -ErrorAction SilentlyContinue
  if ($connection) {
    $listening += $port
  }
}

$memory = Get-CimInstance Win32_OperatingSystem
$freeGB = [math]::Round($memory.FreePhysicalMemory / 1MB, 1)
$totalGB = [math]::Round($memory.TotalVisibleMemorySize / 1MB, 1)

if ($listening.Count -eq $ports.Count) {
  Write-Output "Jarvis stack awake. Free RAM: $freeGB/$totalGB GB."
} else {
  $missing = ($ports | Where-Object { $listening -notcontains $_ }) -join ", "
  Write-Error "Started tasks, but ports not ready yet: $missing"
  exit 1
}
PS
)

ENCODED_COMMAND=$(printf '%s' "$PS_SCRIPT" | iconv -f UTF-8 -t UTF-16LE | base64 | tr -d '\n')
ssh -o ConnectTimeout=8 "$SSH_HOST" powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -EncodedCommand "$ENCODED_COMMAND"
